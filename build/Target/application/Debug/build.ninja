# Utility command for test

build cmake/stm32cubemx/CMakeFiles/test.util: CUSTOM_COMMAND
  COMMAND = cd /RTOSP1/build/Target/application/Debug/cmake/stm32cubemx && /usr/bin/ctest --force-new-ctest-process
  DESC = Running tests...
  pool = console
  restat = 1

build cmake/stm32cubemx/test: phony cmake/stm32cubemx/CMakeFiles/test.util


#############################################
# Utility command for edit_cache

build cmake/stm32cubemx/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /RTOSP1/build/Target/application/Debug/cmake/stm32cubemx && /usr/bin/cmake -E echo No\ interactive\ CMake\ dialog\ available.
  DESC = No interactive CMake dialog available...
  restat = 1

build cmake/stm32cubemx/edit_cache: phony cmake/stm32cubemx/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build cmake/stm32cubemx/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /RTOSP1/build/Target/application/Debug/cmake/stm32cubemx && /usr/bin/cmake --regenerate-during-build -S/RTOSP1 -B/RTOSP1/build/Target/application/Debug
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build cmake/stm32cubemx/rebuild_cache: phony cmake/stm32cubemx/CMakeFiles/rebuild_cache.util

