#############################################
# Custom command for CMakeFiles/docs

build CMakeFiles/docs | ${cmake_ninja_workdir}CMakeFiles/docs: CUSTOM_COMMAND
  COMMAND = cd /RTOSP1 && /usr/bin/doxygen /RTOSP1/Doxyfile
  DESC = Generating documentation with Doxygen


#############################################
# Custom command for CMakeFiles/complexity

build CMakeFiles/complexity | ${cmake_ninja_workdir}CMakeFiles/complexity: CUSTOM_COMMAND
  COMMAND = cd /RTOSP1 && /usr/bin/cmake -E make_directory /RTOSP1/build/documentation/report && /home/builder/.suresh/bin/lizard Core/Src/main.c -l c -w --thresholds nloc=50,ccn=15 -o /RTOSP1/build/documentation/report/complexity_report.log && python3 /RTOSP1/scripts/generate_cc_report.py
  DESC = Generating code complexity analysis with Lizard...


#############################################
# Custom command for CMakeFiles/docs-full

build CMakeFiles/docs-full | ${cmake_ninja_workdir}CMakeFiles/docs-full: CUSTOM_COMMAND || complexity docs
  COMMAND = cd /RTOSP1/build/Target/application/Debug && cmake --build /RTOSP1/build/Target/application/Debug --target docs && cmake --build /RTOSP1/build/Target/application/Debug --target complexity
  DESC = Generating full documentation with Doxygen and complexity analysis...

# =============================================================================
# Write statements declared in CMakeLists.txt:
# /RTOSP1/CMakeLists.txt
# =============================================================================

# =============================================================================
# Object build statements for OBJECT_LIBRARY target STM32_Drivers


#############################################
# Order-only phony target for STM32_Drivers

build cmake_object_order_depends_target_STM32_Drivers: phony || cmake/stm32cubemx/CMakeFiles/STM32_Drivers.dir

build cmake/stm32cubemx/CMakeFiles/STM32_Drivers.dir/__/__/Core/Src/system_stm32l4xx.c.obj: C_COMPILER__STM32_Drivers_Debug /RTOSP1/Core/Src/system_stm32l4xx.c || cmake_object_order_depends_target_STM32_Drivers
  DEFINES = -DDEBUG -DSTM32L412xx -DUSE_HAL_DRIVER
  DEP_FILE = cmake/stm32cubemx/CMakeFiles/STM32_Drivers.dir/__/__/Core/Src/system_stm32l4xx.c.obj.d
  FLAGS = -mcpu=cortex-m4 -mfpu=fpv4-sp-d16 -mfloat-abi=hard  -Wall -fdata-sections -ffunction-sections -mcpu=cortex-m4 -mfpu=fpv4-sp-d16 -mfloat-abi=hard  -Wall -fdata-sections -ffunction-sections -O0 -g3 -std=gnu11
  INCLUDES = -I/RTOSP1/cmake/stm32cubemx/../../Core/Inc -I/RTOSP1/cmake/stm32cubemx/../../Drivers/STM32L4xx_HAL_Driver/Inc -I/RTOSP1/cmake/stm32cubemx/../../Drivers/STM32L4xx_HAL_Driver/Inc/Legacy -I/RTOSP1/cmake/stm32cubemx/../../Middlewares/Third_Party/FreeRTOS/Source/include -I/RTOSP1/cmake/stm32cubemx/../../Middlewares/Third_Party/FreeRTOS/Source/CMSIS_RTOS_V2 -I/RTOSP1/cmake/stm32cubemx/../../Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4F -I/RTOSP1/cmake/stm32cubemx/../../Drivers/CMSIS/Device/ST/STM32L4xx/Include -I/RTOSP1/cmake/stm32cubemx/../../Drivers/CMSIS/Include
  OBJECT_DIR = cmake/stm32cubemx/CMakeFiles/STM32_Drivers.dir
  OBJECT_FILE_DIR = cmake/stm32cubemx/CMakeFiles/STM32_Drivers.dir/__/__/Core/Src
  TARGET_COMPILE_PDB = cmake/stm32cubemx/CMakeFiles/STM32_Drivers.dir/
